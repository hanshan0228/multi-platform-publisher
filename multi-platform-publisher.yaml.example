wechat:
  default: main
  publish:
    default_mode: "auto"
    fallback_order: ["api", "browser"]
  browser:
    enabled: false
    profile_dir: "C:/Users/you/Desktop/ai/multi-platform-publisher/.tmp/wechat-browser-profile"
    browser_path: ""
    headless: false
    login_timeout: 180
    action_timeout: 30
    startup_url: "https://mp.weixin.qq.com/"
    editor_url: "https://mp.weixin.qq.com/cgi-bin/appmsg?t=media/appmsg_edit_v2&action=edit&type=10&isNew=1&lang=zh_CN"
  accounts:
    main:
      name: "My WeChat Official Account"
      app_id: "wx1234567890abcdef"
      app_secret: "your_app_secret_here"
      author: "Author Name"
      theme: "refined-blue"
      image_style: "hand-drawn-blue"
      newspic_image_style: "infographic-warm"
      sync_platforms: [zhihu, juejin]

toutiao:
  cookie_path: "C:/Users/you/.codex/data/toutiao/cookies.json"
  data_dir: "C:/Users/you/.codex/data/toutiao"

xiaohongshu:
  skill_root: "C:/Users/you/Desktop/ai/.tmp/xiaohongshu-skills-inspect"
  default_mode: "fill"
  bridge_url: "ws://localhost:9333"
  browser_executable: "C:/Program Files (x86)/Microsoft/Edge/Application/msedge.exe"
  browser_profile_dir: "C:/Users/you/Desktop/ai/.tmp/xhs-edge-profile"
  extension_path: "C:/Users/you/Desktop/ai/.tmp/xiaohongshu-skills-inspect/extension"
  default_tags: ["AI工具", "效率提升"]

image_generation:
  generator: "baoyu-image-gen"
  provider_order: ["gemini-proxy", "gemini-official", "openai"]
  openai:
    api_key: "sk-..."
    base_url: "https://api.openai.com/v1"
    image_model: "gpt-image-1"
  gemini_proxy:
    base_url: "https://website-data-analysis.replit.app"
    api_key: "cr_..."
    image_model: "gemini-3-pro-image-preview"
  gemini_official:
    api_key: "AIza..."
    base_url: "https://generativelanguage.googleapis.com/v1beta"
    image_model: "gemini-2.5-flash-image-preview"

integrations:
  wechatsync_mcp_token: ""
